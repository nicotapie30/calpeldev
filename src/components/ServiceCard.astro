---
import type { Service } from '../data/services';
interface Props {
  service: Service;
}
const { service } = Astro.props;
---

<article
  class="relative overflow-hidden rounded-2xl border border-border-base bg-bg-secondary/70 backdrop-blur-sm"
  style="will-change: transform; transition: transform 0.35s cubic-bezier(0.23,1,0.32,1), filter 0.35s cubic-bezier(0.23,1,0.32,1);"
>
  <!-- Accent line top -->
  <div
    class="absolute inset-x-0 top-0 h-px"
    style="background: linear-gradient(90deg, transparent, rgba(124,82,232,0.5) 40%, transparent);"
    aria-hidden="true"
  ></div>

  <!-- Número decorativo de fondo -->
  <span
    class="pointer-events-none select-none absolute right-4 top-0 font-mono font-bold leading-none text-white/[0.035]"
    style="font-size: clamp(7rem, 16vw, 13rem);"
    aria-hidden="true"
  >
    {service.number}
  </span>

  <div class="relative z-10 grid grid-cols-1 gap-8 p-8 md:p-10 lg:grid-cols-[1fr_1.2fr] lg:gap-12 lg:p-12">

    <!-- Col izquierda: número + título + tagline + descripción -->
    <div class="flex flex-col gap-5">
      <span class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-accent">
        {service.number}
      </span>
      <div class="flex flex-col gap-3">
        <h3 class="text-2xl font-bold tracking-tight text-text-primary md:text-3xl lg:text-[2rem] leading-tight">
          {service.title}
        </h3>
        <p class="text-base font-medium text-accent-light">
          {service.tagline}
        </p>
      </div>
      <p class="text-[15px] leading-relaxed text-text-secondary">
        {service.description}
      </p>

      <!-- Tags -->
      <div class="mt-auto flex flex-wrap gap-2 pt-2">
        {service.tags.map((tag) => (
          <span class="rounded-full border border-border-base bg-bg-primary/60 px-3 py-1 font-mono text-[11px] text-text-secondary">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Col derecha: features -->
    <div class="flex flex-col gap-3 lg:border-l lg:border-border-base lg:pl-10">
      <p class="mb-1 font-mono text-[11px] font-semibold uppercase tracking-[0.15em] text-text-faint">
        Qué incluye
      </p>
      <ul class="flex flex-col gap-3">
        {service.features.map((feat) => (
          <li class="flex items-start gap-3">
            <span class="mt-[5px] h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
            <span class="text-[15px] leading-snug text-text-secondary">{feat}</span>
          </li>
        ))}
      </ul>
    </div>

  </div>
</article>
